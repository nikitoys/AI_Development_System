{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nikitoys/AI_Development_System/spec/schemas/system-spec.schema.json",
  "title": "AI Development System Spec File",
  "type": "object",
  "required": [
    "spec_id",
    "spec_version",
    "status",
    "markdown_sources",
    "items"
  ],
  "additionalProperties": true,
  "properties": {
    "spec_id": {
      "type": "string",
      "minLength": 1
    },
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Active",
        "Deprecated",
        "Archived"
      ]
    },
    "markdown_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      }
    }
  }
}
